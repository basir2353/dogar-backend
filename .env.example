# Copy to .env for local development. On Railway, set these in the service Variables tab.

NODE_ENV=development
PORT=4000

# Railway API service — link Postgres, then add a REFERENCE (not manual copy of ${{...}}):
#   Variable name: DATABASE_URL
#   Value: reference from PostgreSQL service → DATABASE_URL (private URL)
#
# Or paste the full private URL from Postgres → Variables → DATABASE_URL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/dogar?schema=public"

JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARS
ACCESS_TOKEN_TTL=7d
REFRESH_TOKEN_TTL=7d

# Local uploads folder. On Railway use a volume mount e.g. UPLOAD_DIR=/data/uploads
UPLOAD_DIR=./uploads
STORAGE_DRIVER=local

CSC_API_KEY=
CSC_API_BASE_URL=https://api.countrystatecity.in/v1

# Production CORS — your Vercel app URL (no trailing slash)
FRONTEND_URL=http://localhost:5173
# Optional extra origins (comma-separated): preview/staging URLs
# ALLOWED_ORIGINS=https://dogar-welfare.vercel.app,https://dogar-welfare-git-main-you.vercel.app
# Allow all *.vercel.app preview deployments when true
ALLOW_VERCEL_PREVIEWS=false
