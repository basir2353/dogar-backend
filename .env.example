# Copy to .env and replace placeholders. Do not commit real secrets.

NODE_ENV=development
PORT=4000
# postgresql://DB_USERNAME:DB_PASSWORD@HOST:PORT/DATABASE?schema=public
# The role name (often `postgres`) comes first, then ":" then the password. Not `postgresql://1234@...` (that is user "1234", empty password).
# Create DB:  psql -U postgres -c "CREATE DATABASE dogar;"
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/dogar?schema=public"

JWT_ACCESS_SECRET=CHANGE_ME_MIN_10_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_10_CHARS
# Access token lifetime (e.g. 7d, 12h, 15m). Use 7d so the session matches refresh unless you add client-side refresh.
ACCESS_TOKEN_TTL=7d
REFRESH_TOKEN_TTL=7d

UPLOAD_DIR=./uploads

# Optional: Country / State / City API (cities in profile)
CSC_API_KEY=
CSC_API_BASE_URL=https://api.countrystatecity.in/v1

# CORS: set in production to your web app origin (e.g. https://app.yourorg.org) — no path.
FRONTEND_URL=http://localhost:5173
